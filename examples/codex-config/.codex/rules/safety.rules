# Example only. Review before use.

prefix_rule(
    pattern = ["git", "reset", "--hard"],
    decision = "prompt",
    justification = "Hard reset can erase local work. Check git status and backups first.",
    match = ["git reset --hard"],
    not_match = ["git reset --soft HEAD~1"],
)

prefix_rule(
    pattern = ["git", "push", "--force"],
    decision = "prompt",
    justification = "Force push can overwrite remote history. Confirm branch and team impact first.",
    match = ["git push --force origin main"],
    not_match = ["git push origin main"],
)

prefix_rule(
    pattern = ["gh", "pr", "merge"],
    decision = "prompt",
    justification = "Merging changes project history. Confirm review and checks first.",
    match = ["gh pr merge 12"],
    not_match = ["gh pr view 12"],
)
